---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import HeaderLink from './HeaderLink.astro';
import logoImg from '../assets/logo.png';
import { Image } from 'astro:assets';
---

<header class="premium-header">
	<nav class="navbar">
		<div class="brand">
			<a href="/" class="logo-link">
				<Image src={logoImg} alt={SITE_TITLE} width={150} height={150} class="logo-img" />
			</a>
			<div class="slogan">
				<span class="slogan-main" style="color: #2f3640;">The Rail Post</span>
				<span class="slogan-sub" style="color: #e15f41;">Global News</span>
			</div>
		</div>
		<div class="nav-links">
			<div class="nav-item dropdown">
				<button class="dropbtn">Home <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
				<div class="dropdown-content">
					<a href="/" class="submenu-title" style="text-decoration: none; display: block; font-weight: bold;">Home</a>
					<a href="/about" class="submenu-title" style="text-decoration: none; display: block;">Who We Are</a>
				</div>
			</div>
			
            <div class="nav-item dropdown">
                <button class="dropbtn">Trains <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
                <div class="dropdown-content">
                    <a href="/tags/high-speed" class="submenu-title" style="text-decoration: none; display: block;">High Speed (HSR)</a>
                    <a href="/tags/freight" class="submenu-title" style="text-decoration: none; display: block;">Freight</a>
                    <a href="/tags/regional" class="submenu-title" style="text-decoration: none; display: block;">Regional Trains</a>
                    <a href="/tags/tourism" class="submenu-title" style="text-decoration: none; display: block;">Tourism Trains</a>
                </div>
            </div>
            <div class="nav-item dropdown">
                <button class="dropbtn">More <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
                <div class="dropdown-content">
					<div class="dropdown-submenu">
						<span class="submenu-title">Urban Transport <span>▶</span></span>
						<div class="submenu-content">
							<a href="/tags/lrt">Light Rail (LRT)</a>
							<a href="/tags/metro">Metros</a>
							<a href="/tags/monorail">Monorails</a>
						</div>
					</div>
					<div class="dropdown-submenu">
						<span class="submenu-title">Economy & Data <span>▶</span></span>
						<div class="submenu-content">
							<a href="/tags/costs">Costs & Investments</a>
							<a href="/tags/logistics">Port Logistics</a>
							<a href="/tags/lrt-map">LRT Map</a>
						</div>
					</div>
					<div class="dropdown-submenu">
						<span class="submenu-title">Geography <span>▶</span></span>
						<div class="submenu-content">
							<a href="/tags/brazil">Brazil</a>
							<a href="/tags/americas">Americas</a>
							<a href="/tags/europe">Europe</a>
							<a href="/tags/asia">Asia</a>
							<a href="/tags/world">World</a>
						</div>
					</div>
                </div>
            </div>
		</div>
	</nav>
</header>

<style>
	@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@800&family=Lora:ital,wght@1,500&family=Outfit:wght@500;600&display=swap');

	.premium-header {
		position: sticky;
		top: 0;
		z-index: 1000;
		background: rgba(255, 255, 255, 0.95);
		backdrop-filter: blur(16px);
		border-bottom: 1px solid rgba(0, 0, 0, 0.05);
		padding: 0.5rem 2rem;
		box-shadow: 0 4px 30px rgba(0, 0, 0, 0.03);
	}
	
	.navbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0.5rem 0;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.logo-link { display: flex; align-items: center; width: 140px; height: 100px; margin-right: 20px; }

	.logo-img { height: 100px; width: auto; object-fit: contain; mix-blend-mode: multiply; }

	.slogan {
		display: flex;
		flex-direction: column;
		border-left: 3px solid #eee;
		padding-left: 1.5rem;
		gap: 0.1rem;
	}

	.slogan-main {
		font-family: 'Montserrat', sans-serif;
		font-size: 1.3rem;
		font-weight: 800;
		color: #111;
		letter-spacing: -0.5px;
		text-transform: uppercase;
	}

	.slogan-sub {
		font-family: 'Lora', serif;
		font-size: 1.05rem;
		font-style: italic;
		color: #d32f2f;
		font-weight: 500;
	}

	.badge {
		font-size: 0.6rem;
		background: #ff4757;
		color: white;
		padding: 2px 6px;
		border-radius: 10px;
		vertical-align: super;
		margin-left: 4px;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	.nav-links :global(a) {
		font-family: 'Outfit', sans-serif;
		text-decoration: none;
		color: #333;
		font-weight: 600;
		font-size: 1.1rem;
		transition: color 0.2s;
		padding: 0.5rem 0;
		border-bottom: 2px solid transparent;
	}
	
	.nav-links :global(a:hover) {
		color: #0052D4;
	}
	
	.nav-links :global(a.active) {
		color: #0052D4;
		border-bottom: 2px solid #0052D4;
	}

		/* Dropdown Core */
	.nav-item {
		position: relative;
	}

	.dropbtn {
		font-family: 'Outfit', sans-serif;
		background: none;
		border: none;
		font-size: 1.1rem;
		font-weight: 600;
		color: #333;
		cursor: pointer;
		display: flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.5rem 0;
		transition: color 0.2s;
	}

	.dropbtn:hover {
		color: #0052D4;
	}

	.dropdown-content {
		visibility: hidden;
		opacity: 0;
		position: absolute;
		top: 120%;
		left: 50%;
		transform: translateX(-50%) translateY(10px);
		background: white;
		min-width: 240px;
		border-radius: 12px;
		box-shadow: 0 10px 40px rgba(0,0,0,0.1);
		padding: 0.5rem;
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		z-index: 1000;
	}

	@media (min-width: 769px) {
		.dropdown:hover .dropdown-content {
			visibility: visible;
			opacity: 1;
			transform: translateX(-50%) translateY(0);
		}
	}

	.dropdown-content a {
		display: block;
		padding: 0.7rem 1rem;
		color: #555;
		text-decoration: none;
		border-radius: 6px;
		font-size: 0.95rem;
		transition: all 0.2s;
	}

	.dropdown-content a:hover {
		background: #f4f7fb;
		color: #0052D4;
		padding-left: 1.2rem;
	}

	/* Submenu Core */
	.dropdown-submenu {
		position: relative;
		padding: 0.2rem;
	}

	.submenu-title {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.8rem 1rem;
		color: #444;
		font-weight: 500;
		cursor: pointer;
		border-radius: 8px;
		transition: background 0.2s;
	}

	.submenu-title span {
		font-size: 0.7em;
		color: #aaa;
	}

	.submenu-content {
		visibility: hidden;
		opacity: 0;
		position: absolute;
		top: 0;
		left: 100%;
		margin-left: 0.5rem;
		background: white;
		min-width: 200px;
		border-radius: 12px;
		box-shadow: 0 10px 40px rgba(0,0,0,0.1);
		padding: 0.5rem;
		transform: translateX(10px);
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		z-index: 1000;
	}

	.submenu-content a {
		display: block;
		padding: 0.7rem 1rem;
		color: #555;
		text-decoration: none;
		border-radius: 6px;
		font-size: 0.95rem;
		transition: all 0.2s;
	}

	.submenu-content a:hover {
		background: #f4f7fb;
		color: #0052D4;
		padding-left: 1.2rem;
	}

	@media (min-width: 769px) {
		.dropdown-submenu:hover .submenu-title {
			background: #f4f7fb;
			color: #0052D4;
		}
		.dropdown-submenu:hover .submenu-content {
			visibility: visible;
			opacity: 1;
			transform: translateX(0);
		}
	}

	/* Mobile Responsiveness */
	@media (max-width: 768px) {
		.premium-header {
			padding: 0.5rem 1rem;
		}
		.navbar {
			flex-direction: column;
			gap: 1rem;
		}
		.brand {
			flex-direction: column;
			text-align: center;
			gap: 0.5rem;
		}
		.logo-link {
			margin-right: 0;
			justify-content: center;
		}
		.slogan {
			border-left: none;
			padding-left: 0;
		}
		.nav-links {
			flex-wrap: wrap;
			justify-content: center;
			gap: 0.5rem;
			width: 100%;
		}
		.nav-item {
			position: static;
		}
		.dropdown-content {
			position: absolute;
			top: 100%;
			left: 0;
			width: 100%;
			margin-top: 0;
			transform: none;
			box-shadow: 0 10px 20px rgba(0,0,0,0.1);
			border: none;
			border-top: 1px solid #eee;
			border-radius: 0 0 12px 12px;
			display: none;
			box-sizing: border-box;
			visibility: visible;
			opacity: 1;
			z-index: 1000;
		}
		.dropdown.is-active > .dropdown-content {
			display: block;
			visibility: visible;
			opacity: 1;
		}
		.dropdown-submenu .submenu-content {
			position: static;
			transform: none;
			box-shadow: none;
			border: none;
			margin-left: 1rem;
			border-left: 2px solid #eee;
			border-radius: 0;
			display: none;
			visibility: visible;
			opacity: 1;
		}
		.dropdown-submenu.is-active > .submenu-content {
			display: block;
		}
	}
</style>

<script>
	const dropdowns = document.querySelectorAll('.dropdown');
	dropdowns.forEach(dropdown => {
		const btn = dropdown.querySelector('.dropbtn');
		if (!btn) return;
		btn.addEventListener('click', (e) => {
			if (window.innerWidth <= 768) {
				const isAnchor = e.target.tagName === 'A' || e.target.closest('a');
				if (!isAnchor) {
					e.preventDefault();
					dropdowns.forEach(d => {
					    if (d !== dropdown) d.classList.remove('is-active');
					});
					dropdown.classList.toggle('is-active');
				}
			}
		});
	});

	const submenus = document.querySelectorAll('.dropdown-submenu');
	submenus.forEach(submenu => {
		const title = submenu.querySelector('.submenu-title');
		if (!title) return;
		title.addEventListener('click', (e) => {
			if (window.innerWidth <= 768) {
				const isAnchor = e.target.tagName === 'A' || e.target.closest('a');
				if (!isAnchor) {
					e.preventDefault();
					const parent = submenu.closest('.dropdown-content');
					if (parent) {
					    parent.querySelectorAll('.dropdown-submenu').forEach(s => {
					        if (s !== submenu) s.classList.remove('is-active');
					    });
					}
					submenu.classList.toggle('is-active');
				}
			}
		});
	});

	document.addEventListener('click', (e) => {
		if (window.innerWidth <= 768) {
			const isDropdownClick = e.target.closest('.dropdown');
			if (!isDropdownClick) {
				document.querySelectorAll('.dropdown.is-active').forEach(d => {
					d.classList.remove('is-active');
				});
			}
		}
	});
</script>
