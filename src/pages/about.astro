---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Who We Are | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 800px;
				margin: 0 auto;
				padding: 2em;
			}
			.about-container {
				background: white;
				padding: 3em;
				border-radius: 12px;
				box-shadow: 0 4px 20px rgba(0,0,0,0.05);
			}
			h1 { margin-bottom: 1em; }
			p { font-size: 1.1em; line-height: 1.8; color: #444; margin-bottom: 1.5em; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="about-container">
				<h1>Who We Are</h1>
				<p>
					This site was conceived and is curated by journalist <strong>Miguel do Rosário</strong>, editor-in-chief and founder of the portal <em>O Cafezinho</em>.
				</p>
				<p>
					<strong>Contact:</strong> migueldorosario@gmail.com
				</p>
				<p>
					Based in Niterói, Rio de Janeiro, Miguel is also the creator of the sister network of sites that includes Global South News, Mundo Trilhos, Discover Brazil, and Rail Post, operating with a multipolar vision focused on global technological and social development.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>
